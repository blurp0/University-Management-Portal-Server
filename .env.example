# Server
NODE_ENV=development
PORT=5000

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Database (Supabase)
DATABASE_URL="postgresql://postgres.[USER]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[USER]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

# JWT (generate random 32+ char strings for production)
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Session
SESSION_SECRET=dev-session-secret-change-in-production

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret